# Copy to .env in this folder. Values match the web server (see repo docs/SUPABASE.md).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Portal sign-in (name + password). Pick ONE:
# • Physical phone / Expo Go (recommended): HTTPS production
EXPO_PUBLIC_GM_WEB_URL=https://gm-callout.onrender.com
