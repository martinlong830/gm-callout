# Production values for EAS Build (App Store). Do NOT use localhost or LAN IPs.
# Set these as EAS secrets (recommended) or export before `eas build`:
#   eas secret:create --scope project --name EXPO_PUBLIC_SUPABASE_URL --value "..." --type string

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key

# Public HTTPS URL where gm-callout web server runs (portal sign-in API).
EXPO_PUBLIC_GM_WEB_URL=https://your-production-domain.com

# Optional: only needed in eas.json submit section (or set when running eas submit)
# APPLE_TEAM_ID=XXXXXXXXXX
# ASC_APP_ID=1234567890
