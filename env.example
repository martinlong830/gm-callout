# Copy to .env for local development (never commit .env).

# Twilio (existing voice callouts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_BASE_URL=
PORT=8000

# Supabase (optional — enables cloud auth + DB client in the browser)
# Project Settings → API: Project URL, anon public key, and service_role (server only — never in browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Must be the service_role secret (JWT role "service_role"), NEVER the anon/publishable key.
# Wrong key → companies INSERT RLS error on create-company. Check GET /health → serviceRoleJwtRole.
SUPABASE_SERVICE_ROLE_KEY=

# Password reset + company confirmation emails (Resend — https://resend.com)
# Without RESEND_API_KEY, reset/confirm links are logged to the server console in development only.
# Custom from-address (e.g. noreply@shiflow.app): add + verify domain in Resend → Domains, then set DNS.
RESEND_API_KEY=
PASSWORD_RESET_FROM_EMAIL=Shiflow <onboarding@resend.dev>

# Site URL used in password-reset and company-confirmation email links (local: http://localhost:8000)
PUBLIC_BASE_URL=

# Public support page (/support.html) — optional contact email shown to users
SUPPORT_EMAIL=
