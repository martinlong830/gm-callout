# Copy to .env for local development (never commit .env).

# Twilio (existing voice callouts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_BASE_URL=
PORT=8000

# Supabase (optional — enables cloud auth + DB client in the browser)
# Project Settings → API: Project URL and anon public key
SUPABASE_URL=
SUPABASE_ANON_KEY=
