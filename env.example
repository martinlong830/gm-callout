# Copy to .env for local development (never commit .env).

# Twilio (existing voice callouts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PUBLIC_BASE_URL=
PORT=8000

# Supabase (optional — enables cloud auth + DB client in the browser)
# Project Settings → API: Project URL, anon public key, and service_role (server only — never in browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Password reset emails (Resend — https://resend.com)
# Without RESEND_API_KEY, reset links are logged to the server console in development only.
# Custom from-address (e.g. noreply@shiflow.app): add + verify domain in Resend → Domains, then set DNS.
RESEND_API_KEY=
PASSWORD_RESET_FROM_EMAIL=Red Poke Scheduler <onboarding@resend.dev>
