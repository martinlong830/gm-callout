# Copy to .env for local development (never commit .env).

# Twilio (existing voice callouts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
PORT=8000

# Public HTTPS origin of this app (no trailing slash).
# Local: http://localhost:8000 (or ngrok URL for Twilio voice).
# Production (Render): https://shiflow.app  — NEVER http://localhost:3000
PUBLIC_BASE_URL=

# Optional alias preferred for email confirm / password-reset links (falls back to PUBLIC_BASE_URL).
# Production: https://shiflow.app
SITE_URL=

# Supabase (optional — enables cloud auth + DB client in the browser)
# Project Settings → API: Project URL, anon public key, and service_role (server only — never in browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Must be the service_role secret (JWT role "service_role"), NEVER the anon/publishable key.
# Wrong key → companies INSERT RLS error on create-company. Check GET /health → serviceRoleJwtRole.
SUPABASE_SERVICE_ROLE_KEY=

# Password reset + company confirmation emails (Resend — https://resend.com)
# Without RESEND_API_KEY, reset/confirm links are logged to the server console in development only.
# Custom from-address (e.g. noreply@shiflow.app): add + verify domain in Resend → Domains, then set DNS.
# Display name in Gmail/etc. comes from the text before <email> — use "Shiflow", not "Red Poke Schedule".
RESEND_API_KEY=
PASSWORD_RESET_FROM_EMAIL=Shiflow <noreply@shiflow.app>

# Public support page (/support.html) — contact email shown to users (defaults to support@shiflow.app)
SUPPORT_EMAIL=support@shiflow.app
